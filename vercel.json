{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/tts.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/push-matin",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/push-soir",
      "schedule": "0 18 * * *"
    }
  ]
}