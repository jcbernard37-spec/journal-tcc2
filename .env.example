# ═══════════════════════════════════════════════════════
# Configuration — À copier dans un fichier .env
# ═══════════════════════════════════════════════════════

# Google Drive OAuth (obligatoire pour la synchro)
VITE_GOOGLE_CLIENT_ID=ton_client_id.apps.googleusercontent.com

# ⚠️ La clé Anthropic NE VA PAS ici.
# Elle se met UNIQUEMENT dans Vercel (Settings > Environment Variables)
# sous le nom ANTHROPIC_API_KEY, pour rester secrète côté serveur.
 
# Eleven Labs (optionnel - pages "-pro" avec voix audio reelle) 
VITE_ELEVEN_LABS_KEY=ta_cle_eleven_labs 
